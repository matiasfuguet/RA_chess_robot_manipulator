<?xml version="1.0"?>
<Config>
    <Problemfiles>
        <kautham name="OMPL_RRTConnect_chess_pawn_capture.xml" />
        <pddldomain name="ff-domains/domain_chess.pddl" />
        <pddlproblem name="ff-domains/problem_chess.pddl" />
        <graspit name="" /> <!-- leave it empty if no graspit is to be used -->
    </Problemfiles>
    <States>
        <!-- Real robot TCP positions (robot frame, in metres).
             These are measured directly on the UR3e and used for real execution.
             For Kautham simulation use tampconfig_chess.xml instead. -->
        <Initial>
            <Object name="PEON_NEGRO" kthname="PEON_NEGRO"> -0.05185 -0.32145 -0.35752 0.013345 -0.999580 0.025736 3.147323</Object> <!--
            orientation in axis-angle (vx,vy,vz,theta) like in the kautham problem files-->
            <Object name="PEON_BLANCO" kthname="PEON_BLANCO"> 0.01077 -0.38227 -0.36040 0.012559 -0.999036 0.042071 3.185071</Object>
            <Robot name="ur3_right" controlfile="controls/right_ur3_with_gripper.cntr"> 0.500 0.375
                0.500 0.375 0.500 0.500 0.813 </Robot>
        </Initial>
    </States>
    <Actions>
        <!-- Plan step 2: PICK del peon negro en d5 -->
        <Pick robot="UR3A" object="PEON_NEGRO" region="D5">
            <Rob> ur3_right </Rob>
            <Obj> PEON_NEGRO </Obj>
            <Link> robotiq_85_base_link </Link>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <HomeControls> 0.500 0.375 0.500 0.375 0.500 0.500 0.813 </HomeControls>
<GraspControls grasp="topgrasp"> 0.581986 0.378903 0.810000 0.337875 0.377542 0.954889 0.813 </GraspControls>
        </Pick>
        <!-- Plan step 5: PLACE del peon negro en graveyard -->
        <Place robot="UR3A" object="PEON_NEGRO" region="GRAVEYARD">
            <Rob> ur3_right </Rob>
            <Obj> PEON_NEGRO </Obj>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <HomeControls> 0.500 0.375 0.500 0.375 0.500 0.500 0.813 </HomeControls>
<GraspControls grasp="topgrasp"> 0.400 0.390 0.840 0.320 0.375 0.375 0.813 </GraspControls>
        </Place>
        <!-- Plan step 8: PICK del peon blanco en e4 -->
        <Pick robot="UR3A" object="PEON_BLANCO" region="E4">
            <Rob> ur3_right </Rob>
            <Obj> PEON_BLANCO </Obj>
            <Link> robotiq_85_base_link </Link>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <HomeControls> 0.500 0.375 0.500 0.375 0.500 0.500 0.813 </HomeControls>
<GraspControls grasp="topgrasp"> 0.599500 0.395347 0.775639 0.336583 0.380431 0.972694 0.813 </GraspControls>
        </Pick>
        <!-- Plan step 11: PLACE del peon blanco en d5 -->
        <Place robot="UR3A" object="PEON_BLANCO" region="D5">
            <Rob> ur3_right </Rob>
            <Obj> PEON_BLANCO </Obj>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <HomeControls> 0.500 0.375 0.500 0.375 0.500 0.500 0.813 </HomeControls>
<GraspControls grasp="topgrasp"> 0.581986 0.378903 0.810000 0.337875 0.377542 0.954889 0.813 </GraspControls>
        </Place>
        <!-- Plan step 1: MOVE de home a d5 (tránsito previo al pick del peon negro) -->
        <Move robot="UR3A" region_from="HOME" region_to="D5">
            <Rob> ur3_right </Rob>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <InitControls> 0.500 0.375 0.500 0.375 0.500 0.500 0.813 </InitControls>
            <GoalControls> 0.581986 0.378903 0.810000 0.337875 0.377542 0.954889 0.813 </GoalControls>
        </Move>
        <!-- Plan step 3: MOVE de d5 a home (regreso neutro tras pick del peon negro) -->
        <Move robot="UR3A" region_from="D5" region_to="HOME">
            <Rob> ur3_right </Rob>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <InitControls> 0.581986 0.378903 0.810000 0.337875 0.377542 0.954889 0.813 </InitControls>
            <GoalControls> 0.500 0.375 0.500 0.375 0.500 0.500 0.813 </GoalControls>
        </Move>
        <!-- Plan step 4: MOVE de home a graveyard (tránsito con peon negro para place) -->
        <Move robot="UR3A" region_from="HOME" region_to="GRAVEYARD">
            <Rob> ur3_right </Rob>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <InitControls> 0.500 0.375 0.500 0.375 0.500 0.500 0.813 </InitControls>
            <GoalControls> 0.400 0.385 0.825 0.320 0.375 0.375 0.813 </GoalControls>
        </Move>
        <!-- Plan step 6: MOVE de graveyard a home (regreso neutro tras place del peon negro) -->
        <Move robot="UR3A" region_from="GRAVEYARD" region_to="HOME">
            <Rob> ur3_right </Rob>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <InitControls> 0.400 0.385 0.825 0.320 0.375 0.375 0.813 </InitControls>
            <GoalControls> 0.500 0.375 0.500 0.375 0.500 0.500 0.813 </GoalControls>
        </Move>
        <!-- Plan step 7: MOVE de home a e4 (tránsito previo al pick del peon blanco) -->
        <Move robot="UR3A" region_from="HOME" region_to="E4">
            <Rob> ur3_right </Rob>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <InitControls> 0.500 0.375 0.500 0.375 0.500 0.500 0.813 </InitControls>
            <GoalControls> 0.599500 0.395347 0.775639 0.336583 0.380431 0.972694 0.813 </GoalControls>
        </Move>
        <!-- Plan step 9: MOVE de e4 a home (regreso neutro tras pick del peon blanco) -->
        <Move robot="UR3A" region_from="E4" region_to="HOME">
            <Rob> ur3_right </Rob>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <InitControls> 0.599500 0.395347 0.775639 0.336583 0.380431 0.972694 0.813 </InitControls>
            <GoalControls> 0.500 0.375 0.500 0.375 0.500 0.500 0.813 </GoalControls>
        </Move>
        <!-- Plan step 10: MOVE de home a d5 (tránsito con peon blanco para place final) -->
        <!-- (reutiliza la misma geometria que HOME->D5, ya definida arriba) -->
    </Actions>
</Config>
